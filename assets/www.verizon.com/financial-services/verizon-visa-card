          clearTimeout(tooltipDeactivationTimeout); // Important: Stop any pending deactivation
          active(tooltipBtn);
        });
      }

      // 2. MOUSELEAVE: Defer deactivation to allow the mouse to enter the tooltip content area.
      tooltipBtn.addEventListener("mouseleave", () => {
        tooltipDeactivationTimeout = setTimeout(() => {
          // Only deactivate if the focus is not on the content AND the mouse isn't over the content
          // We check if activeTooltipContent exists and if the mouse is not currently hovering over the button
          if (
            activeTooltipContent &&
            !activeTooltipContent.matches(":hover") &&
            !tooltipBtn.matches(":focus")
          ) {
            deactive(tooltipBtn);
          }
        }, 100);
      });

      // 3. BLUR (Lost Focus): Defer deactivation to allow focus to move to the content.
      tooltipBtn.addEventListener("blur", () => {
        tooltipDeactivationTimeout = setTimeout(() => {
          // Only deactivate if focus has moved outside the button AND is not on the content
          if (document.activeElement !== activeTooltipContent) {
            deactive(tooltipBtn);
          }
        }, 50);
      });

      // 4. CLICK: Immediate activation (for click/tap behavior).
      tooltipBtn.addEventListener("click", (event) => {
        event.stopPropagation();
        event.preventDefault();
        active(tooltipBtn);
      });

      // 5. KEYDOWN: Keyboard shortcuts (Esc, Enter/Space)
      tooltipBtn.addEventListener("keydown", (event) => {
        event.stopPropagation();
        switch (event.code) {
          case "Escape": // esc
            deactive(tooltipBtn, "esc");
            break;
          case "Tab": //tab
            // Blur handler will manage deactivation when tabbing away
            break;
          case "Enter": // enter
          case "Space": // space
            event.preventDefault();
            active(tooltipBtn);
            break;

          default:
            break;
        }
      });
      // --- END FIX ---

      container.dataset.cmpVzrfInitialized = true;
    });
}
function getParentHeadingByClass(pTipElem, pParentClass) {
  let heading = "";
  let parentElem = pTipElem.closest(pParentClass);
  if (parentElem) {
    let headingElem = parentElem.querySelector("h2,h3");
    if (headingElem) {
      heading = headingElem.innerHTML;

      if (heading) {
        heading = heading.trim();
        if (heading.at(-1) == ".") {
          heading = heading.replace(/.$/, "");
        }
      }
    }
  }

  return heading;
}

// NOTE: This function is now modified to be part of the active() flow
// and uses the same deferred deactivation logic.
function addContentListeners(btn, content) {
  // Clear any pending deactivation timeout from the button's mouseleave/blur
  clearTimeout(tooltipDeactivationTimeout);

  // Deactivate tooltip if user presses escape
  content.addEventListener("keydown", (event) => {
    event.stopPropagation();
    if (event.code === "Escape") {
      // esc
      deactive(btn, "esc");
    }
  });

  // Defer deactivation if focus leaves the content
  content.addEventListener("blur", () => {
    tooltipDeactivationTimeout = setTimeout(() => {
      // Only deactivate if the focus has moved outside the tooltip content AND the button
      if (document.activeElement !== btn) {
        deactive(btn);
      }
    }, 50);
  });

  // Defer deactivation if mouse leaves the content
  content.addEventListener("mouseleave", () => {
    tooltipDeactivationTimeout = setTimeout(() => {
      // Only deactivate if the mouse is not over the button
      if (!btn.matches(":hover")) {
        deactive(btn);
      }
    }, 100);
  });

  // Clear deactivation timeout if mouse re-enters the content
  content.addEventListener("mouseenter", () => {
    clearTimeout(tooltipDeactivationTimeout);
  });
}

function active(btn) {
  // Clear any pending deactivation timeout from a previous event
  clearTimeout(tooltipDeactivationTimeout);

  if (btn.getAttribute("aria-expanded") == "false") {
    btn.setAttribute("aria-expanded", "true");
    const container = document.createElement("div");
    container.classList.add("tooltip-container");
    if (!isMobile) {
      container.setAttribute("aria-hidden", "false");
      container.setAttribute("aria-live", "assertive");
      container.setAttribute("aria-relevant", "all");
      document.body.appendChild(container);
      setTimeout(function () {
        container.innerHTML = TooltipContent(btn);

        activeTooltipBtn = btn;
        activeTooltipContent = container.children[0];

        // --- NEW: Add event listeners to the content element ---
        addContentListeners(btn, activeTooltipContent);
        // --- END NEW ---

        SetPosition(activeTooltipBtn, activeTooltipContent);

        // Focus the visible tooltip content for keyboard users
        activeTooltipContent.focus();
      }, 50);

      window.addEventListener("resize", () => {
        if (activeTooltipBtn && activeTooltipContent) {
          SetPosition(activeTooltipBtn, activeTooltipContent);
        }
      });

      btn.nextElementSibling.setAttribute("aria-hidden", "false");
    } else {
      // NOTE: Mobile logic remains unchanged, assuming external logic handles modal focus/close
      TooltipContentForMobile(btn);
      let openTooltipModal = new CustomEvent("openVzModal", {
        detail: {
          selector: "[id='tooltip-mobile-modal']",
          name: "mobile-tooltip-modal",
          modalOutsideClickDisabled: false,
          trigger: btn,
        },
      });
      document.body.dispatchEvent(openTooltipModal);
      var tooltipModalContentDiv = document.getElementById(
        "modal-content-mobile"
      );
      if (tooltipModalContentDiv) tooltipModalContentDiv.scrollTop = 0;
    }
  } else {
    deactive(btn);
  }
}

function deactive(btn, keyType) {
  if (btn.getAttribute("aria-expanded") == "true") {
    // Clear the global timeout to prevent it from closing an already closed tooltip
    clearTimeout(tooltipDeactivationTimeout);

    document
      .querySelectorAll(".tooltip-container")
      .forEach(function (container) {
        container.parentNode.removeChild(container);
      });

    window.removeEventListener("resize", () => {
      SetPosition(activeTooltipBtn, activeTooltipContent);
    });

    activeTooltipBtn = "";
    activeTooltipContent = "";

    btn.setAttribute("aria-expanded", "false");
    // This line assumes btn.nextElementSibling is the screen reader only span
    if (btn.nextElementSibling)
      btn.nextElementSibling.setAttribute("aria-hidden", "true");
    if (keyType == "esc" || keyType == "tab") {
      btn.focus(); // Return focus to the button after closing
    }
  }
}

function TooltipButton(container) {
  const type = container.getAttribute("data-tooltip-type"),
    label = container.getAttribute("data-tooltip-label"),
    content = container.getAttribute("data-tooltip-content");

  const ariaText = container.getAttribute("data-aria-label");
  let tooltipAriaLabel =
    ariaText ||
    getParentHeadingByClass(container, ".Col") ||
    getParentHeadingByClass(container, ".Grid") ||
    "";

  const ariaLabel =
    type == "icon"
      ? tooltipAriaLabel
        ? "More information about " + tooltipAriaLabel + " tooltip"
        : "More information tooltip"
      : label
      ? "More information about " + label + " tooltip"
      : "More information tooltip";
  console.log("arialabel", ariaLabel);

  const elPrevious = container.parentNode.previousSibling;
  if (elPrevious && elPrevious.nodeType === Node.TEXT_NODE) {
    elPrevious.textContent = elPrevious.textContent.trim();
  }
  return `
    <button class="${
      type == "icon"
        ? "Icon Icon--info u-textDecorationNone u-text--xs14 u-text--lg16"
        : "u-textUnderline u-text--10"
    }" tabindex="0" aria-expanded="false" aria-label="${ariaLabel}">
      ${type == "icon" ? "" : label}
    </button>
    <span class="u-screenReaderOnly" aria-label="tooltip" aria-hidden="true">${content}</span>
  `;
}

// NOTE: This function requires jQuery ($) which is not included in the original script.
function TooltipContentForMobile(btn) {
  btn.setAttribute("aria-expanded", "true");
  // Assuming $ is defined globally or imported elsewhere
  var modalContent = $(btn).parent().attr("data-tooltip-content");
  document
    .getElementById("tooltip-mobile-modal")
    .querySelector(".Modal-content").innerHTML = modalContent;
}

function TooltipContent(btn) {
  // tabindex="0" is crucial here for the content to receive focus
  return `
    <div class="Tooltip u-text--10 u-textLineHeightNormal is-active" role="tooltip" tabindex="0" id="vzrf-tooltip-temp">
      <div class="Tooltip-scroll-content"> 
        ${btn.parentElement.getAttribute("data-tooltip-content")}
      </div>
    </div>
  `;
}

function SetPosition(btn, content) {
  const vw = viewportWidth();

  // --- SCROLL ADDITION ---
  //content.style.maxHeight = "16vh"; // Set max height to 16% of viewport height
  //content.style.overflowY = "scroll";
  // -----------------------

  content.style.maxWidth = "300px";
  content.style.position = "absolute";
  content.style.zIndex = "11001";
  content.classList.remove(
    "Tooltip--top",
    "Tooltip--right",
    "Tooltip--left",
    "Tooltip--bottom"
  );

  const btnOffset = offset(btn);

  // Recalculate content width/height after it's in the DOM and styled with max-height
  const contentWidth = content.offsetWidth;
  const contentHeight = content.offsetHeight;

  // Calculate potential horizontal center position
  const centeredLeft = btnOffset.left - (contentWidth - btnOffset.width) / 2;

  // 1. Can it be centered horizontally?
  if (centeredLeft > 0 && centeredLeft + contentWidth < vw) {
    // Check if there is enough space above the button
    if (contentHeight < btnOffset.top) {
      // Top placement
      content.style.left = centeredLeft + "px";
      content.style.top = btnOffset.top - contentHeight + "px";
      content.classList.add("Tooltip--top");
    } else {
      // Bottom placement (Default if not enough space on top)
      content.style.left = centeredLeft + "px";
      content.style.top = btnOffset.top + btnOffset.height + "px"; // Position below the button
      content.classList.add("Tooltip--bottom");
    }
  }
  // 2. Not centered, try Right placement
  else if (btnOffset.left + btnOffset.width + contentWidth + 12 < vw) {
    // Right
    content.style.left = btnOffset.left + btnOffset.width + 12 + "px";
    content.style.width = "auto"; // Let content decide width based on max-width: 300px
    content.style.top =
      btnOffset.top - contentHeight / 2 + btnOffset.height / 2 + "px";
    content.classList.add("Tooltip--right");
  }
  // 3. Not centered or Right, try Left placement
  else {
    // Left
    content.style.left = btnOffset.left - contentWidth - 12 + "px"; // Position to the left
    content.style.width = "auto"; // Let content decide width based on max-width: 300px
    content.style.top =
      btnOffset.top - contentHeight / 2 + btnOffset.height / 2 + "px";
    content.classList.add("Tooltip--left");
  }
}

function offset(el) {
  var rect = el.getBoundingClientRect(),
    scrollLeft = window.pageXOffset || document.documentElement.scrollLeft,
    scrollTop = window.pageYOffset || document.documentElement.scrollTop;
  return {
    top: rect.top + scrollTop,
    left: rect.left + scrollLeft,
    width: rect.width,
    height: rect.height,
  };
}

function viewportWidth() {
  return Math.max(document.documentElement.clientWidth, window.innerWidth || 0);
}

function userAgentSwitchDetector() {
  const currentIsMobile = window.innerWidth < 768;
  if (isMobile !== currentIsMobile) {
    isMobile = currentIsMobile;

    // Manually trigger deactivation if a switch occurs to clean up floating tooltips/modals
    document
      .querySelectorAll(".tooltip-container")
      .forEach(function (container) {
        container.parentNode.removeChild(container);
      });
    activeTooltipBtn = "";
    activeTooltipContent = "";

    // Dispatch a refresh event to re-initialize tooltips based on new screen size
    document.body.dispatchEvent(REFRESH_CMP_REVAL);

    if (!isMobile) {
      console.log("userAgent is set to desktop");
    } else {
      console.log("userAgent is set to mobile");
    }
  }
}

document.addEventListener("DOMContentLoaded", () => {
  initTooltip();
  if (isMobile) {
    console.log("saqib");
    enableMobileTooltipModal();
  }
  window.addEventListener("resize", () => {
    userAgentSwitchDetector();
  });
});
